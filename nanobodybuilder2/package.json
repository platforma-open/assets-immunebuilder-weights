{
  "name": "@platforma-open/milaboratories.immunebuilder-weights-assets.nanobodybuilder2",
  "version": "1.1.0",
  "description": "ImmuneBuilder NanoBodyBuilder2 model weights (Zenodo record 7258553, BSD-3-Clause)",
  "scripts": {
    "cleanup": "rm -rf ./pkg-*.tgz ./pkg-*.zip && rm -rf ./build/ && rm -rf ./dist/ && rm -rf ./indexed_model/",
    "build": "../scripts/download-weights.sh ./modelInfo.json",
    "postbuild": "pl-pkg build && ([ -z \"${CI}\" ] || pl-pkg publish)"
  },
  "block-software": {
    "entrypoints": {
      "main": {
        "asset": {
          "type": "asset",
          "registry": "platforma-open",
          "root": "./indexed_model/nanobodybuilder2"
        }
      }
    }
  },
  "files": [
    "dist/"
  ],
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@platforma-sdk/package-builder": "catalog:"
  }
}
